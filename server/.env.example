DATABASE_URL="postgresql://assetflow:assetflow@localhost:5432/assetflow?schema=public"
JWT_SECRET="super-secret-assetflow-dev-key-change-me"
JWT_EXPIRES_IN="24h"
PORT=4000
WEB_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# Email (SMTP). Leave all blank to use a zero-config Ethereal test inbox in dev
# (welcome + password-reset emails print a preview URL to the server console).
# For real delivery (e.g. Gmail app password, SendGrid, Mailgun), set these:
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="AssetFlow <no-reply@assetflow.io>"
